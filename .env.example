# Copy this file to .env and fill in your real values.
# Do not commit .env to version control.

# OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Supabase project URL (Dashboard -> Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/key or service_role key (Dashboard -> Settings -> API)
# Use service_role for seed scripts and backend if you need to bypass RLS.
SUPABASE_API_KEY=your-supabase-anon-or-service-role-key-here

# TMDB API key
TMDB_API_KEY=your_tmdb_api_key_here

# Cloudflare AI Gateway auth token (used by Worker, keep secret)
API_TOKEN=your_cloudflare_aig_token_here

# Optional frontend override.
# Frontend now defaults to the deployed Worker URL when this is unset.
# For local Express backend testing, uncomment:
# VITE_API_URL=http://localhost:3001

# Optional timeout override (ms)
OPENAI_TIMEOUT_MS=90000
