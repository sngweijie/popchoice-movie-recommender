{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "movie",
  "main": "worker/index.js",
  "compatibility_date": "2026-03-15",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "OPENAI_TIMEOUT_MS": "90000",
    "OPENAI_CHAT_MODEL": "openai/gpt-5-nano"
  }
}
